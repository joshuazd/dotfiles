#!/usr/bin/env bash
#
# tmux-monitor - Live-updating tmux session status table
#
# Usage: tmux-monitor [-i SECONDS]
#
# Displays a continuously refreshing table of all tmux sessions with
# git status information. Runs outside tmux.
#
# Architecture: three concurrent actors sharing data via files in tmpdir:
#   Render loop (foreground, every 3s) — reads tmux state, reads cache, draws table
#   Git worker  (background, every 3s) — reads manifest, writes git/<session> files
#   PR worker   (background, every 30s) — reads git/* files, writes pr/<branch> files

set -o errexit
set -o nounset
set -o pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/common.sh"

INTERVAL=3
GIT_INTERVAL=3
PR_INTERVAL=30

# Colors
BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
BRIGHT_GREEN='\033[92m'
BRIGHT_RED='\033[91m'
BRIGHT_YELLOW='\033[93m'

# Column widths
COL_SESSION=52
COL_GIT=18
COL_PR=20

# Tmpdir for inter-process cache
tmpdir=""
worker_pids=()

#######################################
# Truncate a string to max N chars, appending … if truncated
#######################################
trunc() {
  local max="${1}" str="${2}"
  if [[ "${#str}" -gt "${max}" ]]; then
    printf "%s…" "${str:0:$(( max - 1 ))}"
  else
    printf "%s" "${str}"
  fi
}

#######################################
# Atomic write: write to tmp file, then mv
# Arguments:
#   dest — target file path
#   content — string to write
#######################################
atomic_write() {
  local dest="${1}" content="${2}"
  local tmp="${dest%/*}/.${dest##*/}.tmp"
  printf '%s' "${content}" > "${tmp}" 2>/dev/null || return 0
  mv -f "${tmp}" "${dest}" 2>/dev/null || return 0
}

#######################################
# Compute git status column string
# Arguments:
#   path   — git repo path
#   branch — current branch name
# Outputs:
#   e.g. "~3 +1 -1 ↑ 2" or "—"
#######################################
git_status_col() {
  local path="${1}"
  local branch="${2}"

  local porcelain
  porcelain="$(git --no-optional-locks -C "${path}" status --porcelain 2>/dev/null || true)"

  local modified=0 added=0 deleted=0
  if [[ -n "${porcelain}" ]]; then
    while IFS= read -r line; do
      local xy="${line:0:2}"
      case "${xy}" in
        "M "|" M"|"MM") (( modified++ )) ;;
        "A "|"??")      (( added++ )) ;;
        "D "|" D")      (( deleted++ )) ;;
        *)
          case "${xy:0:1}" in
            R|U) (( modified++ )) ;;
            C)   (( added++ )) ;;
          esac
          case "${xy:1:1}" in
            M) (( modified++ )) ;;
            D) (( deleted++ )) ;;
          esac
          ;;
      esac
    done <<< "${porcelain}"
  fi

  local unpushed=0
  local remote_ref
  remote_ref="$(git -C "${path}" rev-parse --verify "origin/${branch}" 2>/dev/null || true)"
  if [[ -n "${remote_ref}" ]]; then
    unpushed="$(git -C "${path}" rev-list "origin/${branch}..HEAD" --count 2>/dev/null || echo 0)"
  fi

  local parts=()
  [[ "${modified}" -gt 0 ]] && parts+=("~${modified}")
  [[ "${added}" -gt 0 ]]    && parts+=( "+${added}")
  [[ "${deleted}" -gt 0 ]]  && parts+=("-${deleted}")
  [[ "${unpushed}" -gt 0 ]] && parts+=("↑ ${unpushed}")

  if [[ "${#parts[@]}" -eq 0 ]]; then
    printf "—"
  else
    local IFS=' '
    printf "%s" "${parts[*]}"
  fi
}

#######################################
# Extract owner/repo from a git remote URL
# Handles both SSH and HTTPS formats
#######################################
remote_to_nwo() {
  local url="${1}"
  url="${url%.git}"
  url="${url#*github.com:}"
  url="${url#*github.com/}"
  printf "%s" "${url}"
}

#######################################
# Git worker — runs in background
# Reads sessions.manifest, writes git/<session> cache files
#######################################
start_git_worker() {
  set +o errexit
  local first=1

  while true; do
    if [[ "${first}" -eq 1 ]]; then
      first=0
    else
      sleep "${GIT_INTERVAL}" || true
    fi

    [[ -f "${tmpdir}/sessions.manifest" ]] || continue

    while IFS='|' read -r session pane_path; do
      [[ -z "${session}" ]] && continue

      local git_root=""
      local branch=""
      local gcol="—"

      git_root="$(git -C "${pane_path}" rev-parse --show-toplevel 2>/dev/null || true)"
      if [[ -n "${git_root}" ]]; then
        branch="$(git -C "${git_root}" branch --show-current 2>/dev/null || true)"
        if [[ -n "${branch}" ]]; then
          gcol="$(git_status_col "${git_root}" "${branch}")"
        fi
      fi

      atomic_write "${tmpdir}/git/${session//\//__}" "${branch}|${git_root}|${gcol}"
    done < "${tmpdir}/sessions.manifest"
  done
}

#######################################
# PR worker — runs in background
# Reads git/* cache files to build branch→repo map, fetches PR data
#######################################
start_pr_worker() {
  # Workers run in subshells — disable errexit so benign failures don't kill us
  set +o errexit

  # Wait for git worker to populate cache before first PR fetch
  while ! compgen -G "${tmpdir}/git/*" >/dev/null 2>&1; do
    sleep 1
  done

  local first=1

  while true; do
    if [[ "${first}" -eq 1 ]]; then
      first=0
    else
      sleep "${PR_INTERVAL}" || true
    fi

    # Build branch→repo map from git cache files
    local -A branch_to_repo=()
    local -A seen_branches=()

    for git_file in "${tmpdir}/git"/*; do
      [[ -f "${git_file}" ]] || continue
      local data
      data="$(<"${git_file}")"
      local branch git_root _gcol
      IFS='|' read -r branch git_root _gcol <<< "${data}"
      [[ -z "${branch}" || -z "${git_root}" ]] && continue
      [[ -n "${seen_branches["${branch}"]:-}" ]] && continue
      seen_branches["${branch}"]=1
      branch_to_repo["${branch}"]="${git_root}"
    done

    # Fetch PR data for each branch
    for branch in "${!branch_to_repo[@]}"; do
      local repo_path="${branch_to_repo["${branch}"]}"
      local remote_url
      remote_url="$(git -C "${repo_path}" remote get-url origin 2>/dev/null || true)"
      [[ -z "${remote_url}" ]] && continue

      local json
      json="$(cd "${repo_path}" && gh pr view "${branch}" \
        --json number,state,isDraft,url,statusCheckRollup,reviewDecision,latestReviews 2>/dev/null || true)"

      if [[ -n "${json}" ]]; then
        local number state isDraft url checks
        number="$(printf '%s' "${json}" | jq -r '.number')"
        state="$(printf '%s' "${json}" | jq -r '.state')"
        isDraft="$(printf '%s' "${json}" | jq -r '.isDraft')"
        url="$(printf '%s' "${json}" | jq -r '.url')"

        local check_statuses
        check_statuses="$(printf '%s' "${json}" | jq -r \
          '.statusCheckRollup // [] | .[] | (.conclusion // .status // .state // empty)')"
        if [[ -z "${check_statuses}" ]]; then
          checks=""
        elif printf '%s\n' "${check_statuses}" | grep -qiE 'FAILURE|ERROR'; then
          checks="fail"
        elif printf '%s\n' "${check_statuses}" | grep -qiE 'PENDING|QUEUED|IN_PROGRESS|WAITING'; then
          checks="pending"
        else
          checks="pass"
        fi

        local review
        review="$(printf '%s' "${json}" | jq -r '.reviewDecision // empty')"

        local approvals
        approvals="$(printf '%s' "${json}" | jq '[.latestReviews // [] | .[] | select(.state == "APPROVED")] | length')"

        local unresolved=0
        if [[ "${state}" == "OPEN" ]]; then
          local threads_json
          threads_json="$(cd "${repo_path}" && gh api graphql -f query='
            query($owner: String!, $repo: String!, $number: Int!) {
              repository(owner: $owner, name: $repo) {
                pullRequest(number: $number) {
                  reviewThreads(first: 100) {
                    nodes { isResolved isOutdated }
                  }
                }
              }
            }
          ' -F owner='{owner}' -F repo='{repo}' -F number="${number}" 2>/dev/null || true)"
          if [[ -n "${threads_json}" ]]; then
            unresolved="$(printf '%s' "${threads_json}" | jq '[.data.repository.pullRequest.reviewThreads.nodes[] | select(.isResolved == false and .isOutdated == false)] | length')"
          fi
        fi

        atomic_write "${tmpdir}/pr/${branch//\//__}" "${number}|${state}|${isDraft}|${url}|${checks}|${review}|${approvals}|${unresolved}"
      else
        atomic_write "${tmpdir}/pr/${branch//\//__}" ""
      fi
    done
  done
}

#######################################
# Format PR column for a given branch
# Arguments:
#   branch — branch name
# Outputs:
#   Colorized PR string with OSC 8 hyperlink
#######################################
pr_col() {
  local branch="${1}"
  local pr_file="${tmpdir}/pr/${branch//\//__}"

  if [[ ! -f "${pr_file}" ]]; then
    printf "—"
    return
  fi

  local cached
  cached="$(<"${pr_file}")"

  if [[ -z "${cached}" ]]; then
    printf "—"
    return
  fi

  local number state isDraft url checks review approvals unresolved
  IFS='|' read -r number state isDraft url checks review approvals unresolved <<< "${cached}"

  local color label
  if [[ "${isDraft}" == "true" ]]; then
    color="${DIM}"
    label="Draft"
  elif [[ "${state}" == "MERGED" ]]; then
    color="${PURPLE}"
    label="Merged"
  elif [[ "${state}" == "CLOSED" ]]; then
    color="${RED}"
    label="Closed"
  else
    color="${GREEN}"
    label="Open"
  fi

  # OSC 8 hyperlink + color
  printf "%b\\033]8;;%s\\033\\\\#%s\\033]8;;\\033\\\\%b" \
    "${color}" "${url}" "${number}" "${RESET}"

  # Check status indicator
  case "${checks:-}" in
    pass)    printf " %b✓%b" "${BRIGHT_GREEN}" "${RESET}" ;;
    fail)    printf " %b✗%b" "${BRIGHT_RED}" "${RESET}" ;;
    pending) printf " %b●%b" "${BRIGHT_YELLOW}" "${RESET}" ;;
  esac

  # Review decision indicator (open PRs only)
  if [[ "${state}" == "OPEN" ]]; then
    case "${review:-}" in
      APPROVED)          printf " %b☑%b" "${BRIGHT_GREEN}" "${RESET}" ;;
      CHANGES_REQUESTED) printf " %b✎%b" "${BRIGHT_RED}" "${RESET}" ;;
      *)
        # Show partial approvals even when overall decision isn't APPROVED
        if [[ "${approvals:-0}" -gt 0 ]]; then
          printf " %b☑%b" "${BRIGHT_YELLOW}" "${RESET}"
        fi
        ;;
    esac

    # Unresolved review comments indicator (open PRs only)
    if [[ "${unresolved:-0}" -gt 0 ]]; then
      printf " %b☐ %s%b" "${BRIGHT_YELLOW}" "${unresolved}" "${RESET}"
    fi
  fi
}

#######################################
# Setup terminal for live updates
#######################################
setup_terminal() {
  tput civis 2>/dev/null || true   # hide cursor
  tput clear 2>/dev/null || true
}

#######################################
# Restore terminal on exit
#######################################
restore_terminal() {
  tput cnorm 2>/dev/null || true   # show cursor
  tput sgr0 2>/dev/null || true    # reset attributes
  printf "\n"
}

#######################################
# Cleanup: kill workers, remove tmpdir, restore terminal
#######################################
cleanup() {
  for pid in "${worker_pids[@]}"; do
    kill "${pid}" 2>/dev/null || true
    wait "${pid}" 2>/dev/null || true
  done
  worker_pids=()
  [[ -n "${tmpdir}" ]] && \rm -rf "${tmpdir}"
  restore_terminal
}

#######################################
# Render the table from tmux state + cached data
#######################################
render() {
  local current_session
  current_session="$(tmux display-message -p '#{session_name}')"
  local last_session
  last_session="$(tmux list-sessions -F '#{session_activity}|#{session_name}' 2>/dev/null \
    | sort -t'|' -k1,1rn \
    | while IFS='|' read -r _ts name; do
        [[ "${name}" != "${current_session}" ]] && printf '%s' "${name}" && break
      done)"

  local -a sessions=()
  local -a pane_paths=()

  while IFS='|' read -r session pane_path; do
    sessions+=("${session}")
    pane_paths+=("${pane_path}")
  done < <(tmux list-panes -a \
    -F '#{session_created}|#{session_name}|#{pane_current_path}' \
    -f '#{&&:#{==:#{window_index},1},#{==:#{pane_index},1}}' 2>/dev/null \
    | sort -t'|' -k1,1n | cut -d'|' -f2-)

  # Write sessions.manifest for workers
  local manifest=""
  local i
  for i in "${!sessions[@]}"; do
    manifest+="${sessions[$i]}|${pane_paths[$i]}"$'\n'
  done
  atomic_write "${tmpdir}/sessions.manifest" "${manifest}"

  # Collect bell flags
  local -A bell_sessions=()
  while IFS='|' read -r sess flag; do
    if [[ "${flag}" == "1" ]]; then
      bell_sessions["${sess}"]=1
    fi
  done < <(tmux list-windows -a -F '#{session_name}|#{window_bell_flag}' 2>/dev/null)

  # Read git cache for each session
  local -a branches=()
  local -a gcols=()

  for i in "${!sessions[@]}"; do
    local session="${sessions[$i]}"
    local git_file="${tmpdir}/git/${session//\//__}"
    local branch="" gcol="—"

    if [[ -f "${git_file}" ]]; then
      local data
      data="$(<"${git_file}")"
      local _git_root
      IFS='|' read -r branch _git_root gcol <<< "${data}"
    fi

    branches+=("${branch}")
    gcols+=("${gcol}")
  done

  # Move cursor to top-left and start drawing
  tput cup 0 0

  # Header
  printf "  ${BOLD}${CYAN}%s %-${COL_SESSION}s  %-${COL_GIT}s  %-${COL_PR}s${RESET}\033[K\n" " " "Session" "Git" "PR"
  local divider_len=$(( COL_SESSION + COL_GIT + COL_PR + 9 ))
  printf "  ${DIM}%s${RESET}\033[K\n" "$(printf '─%.0s' $(seq 1 "${divider_len}"))"

  for i in "${!sessions[@]}"; do
    local session="${sessions[$i]}"
    local branch="${branches[$i]}"
    local gcol="${gcols[$i]}"
    local pcol

    if [[ -n "${branch}" ]]; then
      pcol="$(pr_col "${branch}")"
    else
      pcol="—"
    fi

    # Format session column: yellow + asterisk when bell is active
    local session_display
    local has_bell="${bell_sessions["${session}"]:-}"
    if [[ -n "${has_bell}" ]]; then
      local truncated
      truncated="$(trunc $(( COL_SESSION - 2 )) "${session}")"
      local pad=$(( COL_SESSION - ${#truncated} - 2 ))
      session_display="${YELLOW}${truncated} *${RESET}"
      [[ "${pad}" -gt 0 ]] && session_display+="$(printf '%*s' "${pad}" '')"
    else
      session_display="$(trunc "${COL_SESSION}" "${session}")"
      local pad=$(( COL_SESSION - ${#session_display} ))
      [[ "${pad}" -gt 0 ]] && session_display+="$(printf '%*s' "${pad}" '')"
    fi

    # PR column contains escape sequences — pad manually
    local pr_text
    if [[ "${pcol}" == "—" ]]; then
      pr_text="$(printf "%-${COL_PR}s" "—")"
    else
      local visible
      visible="$(printf '%b' "${pcol}" | sed $'s/\033[[][0-9;]*m//g; s/\033]8;;[^\033]*\033\\\\//g')"
      local pr_pad=$(( COL_PR - ${#visible} ))
      pr_text="${pcol}"
      [[ "${pr_pad}" -gt 0 ]] && pr_text+="$(printf '%*s' "${pr_pad}" '')"
    fi

    # Git column may contain multi-byte UTF-8 (↑, —) — pad manually
    local git_visible_len
    git_visible_len="$(printf '%s' "${gcol}" | LC_ALL=en_US.UTF-8 wc -m | tr -d ' ')"
    local git_pad=$(( COL_GIT - git_visible_len ))
    local git_text="${gcol}"
    [[ "${git_pad}" -gt 0 ]] && git_text+="$(printf '%*s' "${git_pad}" '')"

    # Session indicator
    local indicator=" "
    if [[ "${session}" == "${current_session}" ]]; then
      indicator="▸"
    elif [[ "${session}" == "${last_session}" ]]; then
      indicator="·"
    fi

    printf "  %s %b  %s  %b\033[K\n" "${indicator}" "${session_display}" "${git_text}" "${pr_text}"
  done

  printf "\033[K\n"
  printf "  ${DIM}Refreshing every %ds · Ctrl-C to exit${RESET}\033[K" "${INTERVAL}"

  # Erase any stale lines below (ANSI CSI J — more reliable than tput ed)
  printf '\033[J'
}

#######################################
# Main
#######################################
main() {
  if help_wanted "${@}"; then
    printf "Usage: tmux-monitor [-i SECONDS]\n\n"
    printf "Live-updating tmux session status table.\n\n"
    printf "Options:\n"
    printf "  -i, --interval SECONDS  Refresh interval (default: 3)\n"
    exit 0
  fi

  while [[ "${#}" -gt 0 ]]; do
    case "${1}" in
      -i|--interval) INTERVAL="${2}"; shift 2 ;;
      *) error "Unknown option: ${1}"; exit 1 ;;
    esac
  done

  if ! tmux list-sessions &>/dev/null; then
    error "No tmux server running"
    exit 1
  fi

  # Setup tmpdir and cache subdirs
  tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/tmux-monitor.XXXXXX")"
  mkdir -p "${tmpdir}/git" "${tmpdir}/pr"

  trap cleanup EXIT INT TERM
  trap 'tput clear 2>/dev/null; render' WINCH
  setup_terminal

  # Start background workers
  start_git_worker &
  worker_pids+=($!)
  start_pr_worker &
  worker_pids+=($!)

  while true; do
    render
    sleep "${INTERVAL}" || true  # sleep interrupted by WINCH returns non-zero
  done
}

main "${@}"
