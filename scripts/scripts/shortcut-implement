#!/usr/bin/env bash
#
# shortcut-implement - Implement a Shortcut story with Claude
#
# Usage: shortcut-implement [--detached] [-d] [--non-interactive] [--tier T] [--reasoning R] <story-url-or-id>
#
# Fetches a Shortcut story, sets up a worktree session, builds an implementation
# prompt from the story title and description, and launches Claude interactively
# in the 'ai' tmux window pre-seeded with the story context.
#
# Arguments:
#   --detached, -d      Create session without switching to it (optional)
#   --non-interactive   Don't wait for user input before closing popup (optional)
#   --tier T            Force model tier (opus|sonnet|haiku). Skips classifier. (optional)
#   --reasoning R       Force reasoning effort (xhigh|high|medium|low). (optional)
#   story-url-or-id     Shortcut story URL, sc-12345, or numeric ID
#
# Example:
#   shortcut-implement sc-12345
#   shortcut-implement 12345
#   shortcut-implement https://app.shortcut.com/workspace/story/12345
#   shortcut-implement --detached sc-12345
#   shortcut-implement --non-interactive 12345

set -o errexit   # abort on nonzero exitstatus
set -o nounset   # abort on unbound variable
set -o pipefail  # don't hide errors within pipes

# Get script directory and source common functions
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/common.sh"

#######################################
# Print usage information
# Outputs:
#   Writes usage information to stdout
#######################################
usage() {
  cat <<USAGE
Usage: ${0##*/} [--detached] [--non-interactive] [--tier T] [--reasoning R] <story-url-or-id>

Implement a Shortcut story with Claude.

Arguments:
  --detached, -d      Create session without switching to it (optional)
  --non-interactive   Don't wait for user input before closing popup (optional)
  --tier T            Force model tier (opus|sonnet|haiku). Skips classifier. (optional)
  --reasoning R       Force reasoning effort (xhigh|high|medium|low). (optional)
  story-url-or-id     Shortcut story URL, sc-12345, or numeric ID

The script will:
  1. Fetch the story details from Shortcut
  2. Open a tmux popup to create a worktree and tmux session
  3. Build an implementation prompt from the story title and description
  4. Launch Claude in the 'ai' window with the implementation prompt
  5. Switch to the 'ai' window (unless --detached)

Examples:
  ${0##*/} sc-12345
    Implements story sc-12345 (interactive popup)

  ${0##*/} 12345
    Implements story 12345 (numeric ID)

  ${0##*/} https://app.shortcut.com/workspace/story/12345
    Implements story from URL

  ${0##*/} --detached sc-12345
    Sets up session without switching to it

  ${0##*/} --non-interactive sc-12345
    Implements story without waiting for user confirmation
USAGE
}

#######################################
# Main function
# Arguments:
#   Optional --detached / --non-interactive flags and story URL or ID
# Returns:
#   0 on success, 1 on failure
#######################################
main() {
  local detached=false
  local interactive=true
  local story_input=""
  local tier_override=""
  local reasoning_override=""
  local story_id
  local summary
  local branch_name
  local session_script
  local current_dir
  local session_name

  # Parse arguments
  while [ "${#}" -gt 0 ]; do
    case "${1}" in
      --detached|-d)
        detached=true
        shift
        ;;
      --non-interactive)
        interactive=false
        shift
        ;;
      --tier)
        tier_override="${2}"
        shift 2
        ;;
      --reasoning)
        reasoning_override="${2}"
        shift 2
        ;;
      -*)
        error "Unknown option: ${1}"
        return 1
        ;;
      *)
        story_input="${1}"
        shift
        ;;
    esac
  done

  # Check if story input was provided
  if [ -z "${story_input}" ]; then
    error "Missing required argument: story-url-or-id"
    printf "\\n"
    usage
    return 1
  fi

  # Check if we're in tmux
  if ! is_in_tmux; then
    error "Not running in tmux"
    error "This script requires tmux to be running"
    return 1
  fi

  # Check if short command is available
  if ! command -v short > /dev/null 2>&1; then
    error "Shortcut CLI 'short' not found"
    error "Please install it first"
    return 1
  fi

  # Get the path to git-worktree-session script
  session_script="$(resolve_session_script "${SCRIPT_DIR}")" || return 1

  current_dir="$(pwd)"
  story_id="$(extract_story_id "${story_input}")"

  info "Fetching story ${story_id} from Shortcut..."
  summary="$(fetch_story_summary "${story_id}")"
  local story_title="${summary%%$'\t'*}"
  branch_name="${summary#*$'\t'}"

  if [ -z "${branch_name}" ] || [ "${branch_name}" = "${summary}" ]; then
    error "No branch name found for story ${story_id}"
    return 1
  fi

  info "Ensuring story ownership..."
  "${SCRIPT_DIR}/shortcut-claim" --quiet "${story_id}"

  info "Found branch: ${branch_name}"

  local dir_name="sc-${story_id}"
  session_name="$(session_name_from_title "SC" "${story_id}" "${story_title}")"

  # Route: classify story or honor manual overrides.
  local route_json
  if [ -n "${tier_override}" ]; then
    route_json="$(manual_route "${tier_override}" "${reasoning_override:-xhigh}")"
  else
    info "Classifying story for model routing..."
    route_json="$(classify_story "${story_id}")"
  fi
  local route_model route_reasoning route_rationale
  IFS=$'\t' read -r route_model route_reasoning route_rationale <<<"$(parse_route "${route_json}")"
  info "Routing: ${route_model} / ${route_reasoning} — ${route_rationale}"

  # Pass --detached so run_worktree_popup skips switch-client;
  # we switch to :claude ourselves below.
  local -a popup_args=("--detached" "--dir-name" "${dir_name}" "--session-name" "${session_name}")
  ${interactive} || popup_args+=("--non-interactive")
  run_worktree_popup "${popup_args[@]}" "${current_dir}" "${session_script}" "${branch_name}" "${session_name}"

  # Plan mode for anything that benefits from a planning step: opus,
  # opusplan, and sonnet+high. sonnet+medium is mechanical enough to skip it.
  local -a extra_flags=()
  case "${route_model}" in
    opus|opusplan) extra_flags=("--permission-mode" "plan") ;;
    sonnet)
      [ "${route_reasoning}" = "high" ] && extra_flags=("--permission-mode" "plan")
      ;;
  esac

  info "Launching Claude in claude window..."
  # The execution-default block survives the plan-accept context clear
  # (showClearContextOnPlanAccept). Without it, the implement skill's
  # "default to subagent-driven-development" instruction is wiped along
  # with the planning conversation, and the model falls back to inline
  # executing-plans by default.
  local execution_default='<execution-default>
After plan-accept, default to invoking superpowers:subagent-driven-development for execution. Each task runs in a fresh subagent with its own context budget and two-stage review (spec then code-quality). Fall back to superpowers:executing-plans only when plan tasks are tightly coupled (e.g., a single migration + model change that must ship together) or the work is so small (1-2 tasks) that subagent overhead outweighs the benefit.
</execution-default>'
  local launch_cmd
  launch_cmd="$(claude_launch_cmd \
    "${route_model}" "${route_reasoning}" "${route_rationale}" \
    "/implement ${story_id}" "${execution_default}" "${extra_flags[@]}")"
  tmux send-keys -t "=${session_name}:claude" "${launch_cmd}" Enter

  if ! ${detached}; then
    tmux switch-client -t "=${session_name}:claude"
  fi

  return 0
}

# Check for help flag
if help_wanted "${@}"; then
  usage
  exit 0
fi

# Run main function
main "${@}"
