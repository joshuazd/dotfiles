#!/bin/sh
set -o errexit -o nounset

# Resolve to dotfiles root regardless of whether run directly or via ~/.bin symlink
self="$0"
while [ -L "$self" ]; do
    self_dir="$(cd "$(dirname "$self")" && pwd)"
    self="$self_dir/$(readlink "$self")"
done
DOTFILES="$(cd "$(dirname "$self")/../.." && pwd)"

if ! command -v stow >/dev/null 2>&1; then
    echo "install-symlinks: stow not found — run 'jzd-install tools' first" >&2
    exit 1
fi

cd "$DOTFILES"

for pkg in vim shell tmux git config scripts claude; do
    if [ -d "$pkg" ]; then
        echo "Stowing $pkg..."
        stow --restow "$pkg"
    fi
done

echo "Symlinks installed."
