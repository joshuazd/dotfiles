#!/bin/sh
set -o errexit -o nounset

TAG="${1:-core}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ "$(uname)" = "Darwin" ]; then
    exec "$SCRIPT_DIR/install-tools-mac" "$TAG"
fi

if [ -f /etc/os-release ]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    case "${ID:-}" in
        ubuntu|debian|*ubuntu*|*debian*|linuxmint|pop)
            exec "$SCRIPT_DIR/install-tools-apt" "$TAG" ;;
        fedora|rhel|centos|amzn|rocky|almalinux)
            exec "$SCRIPT_DIR/install-tools-dnf" "$TAG" ;;
        arch|manjaro|endeavouros|garuda)
            exec "$SCRIPT_DIR/install-tools-pacman" "$TAG" ;;
        alpine)
            exec "$SCRIPT_DIR/install-tools-apk" "$TAG" ;;
    esac
fi

# Fallback: detect by available package manager
if command -v apt-get >/dev/null 2>&1; then
    exec "$SCRIPT_DIR/install-tools-apt" "$TAG"
elif command -v dnf >/dev/null 2>&1 || command -v yum >/dev/null 2>&1; then
    exec "$SCRIPT_DIR/install-tools-dnf" "$TAG"
elif command -v pacman >/dev/null 2>&1; then
    exec "$SCRIPT_DIR/install-tools-pacman" "$TAG"
elif command -v apk >/dev/null 2>&1; then
    exec "$SCRIPT_DIR/install-tools-apk" "$TAG"
else
    echo "install-tools: could not detect package manager" >&2
    exit 1
fi
