#!/bin/sh

cd "$(dirname "$0")" || exit 1

option="${1:-}"

case "$option" in
    symlinks)
        exec "$HOME/.bin/install-symlinks" ;;
    tools)
        exec "$HOME/.bin/install-tools" "${2:-}" ;;
    all)
        exec "$HOME/.bin/install-all" "${2:-}" ;;
    *)
        echo "Usage: jzd install <command> [tag]"
        echo ""
        echo "Commands:"
        echo "  all [core|full]      Install tools and symlinks"
        echo "  tools [core|full]    Install packages only"
        echo "  symlinks             Stow dotfile symlinks"
        ;;
esac
