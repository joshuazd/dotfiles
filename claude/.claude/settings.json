{
  "permissions": {
    "allow": [
      "Bash(bundle exec rubocop*)",
      "Bash(bundle exec rspec*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git status*)",
      "Bash(git blame*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git stash*)",
      "Bash(git grep*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr status*)",
      "Bash(gh pr checks*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(gh repo view*)",
      "Bash(gh release view*)",
      "Bash(gh release list*)",
      "Bash(gh workflow list*)",
      "Bash(gh workflow view*)",
      "Bash(gh pr:*)",
      "Bash(jq*)",
      "Bash(short story*)",
      "Skill(*)",
      "mcp__plugin_slack_slack__slack_read_thread",
      "mcp__datadog-mcp__analyze_datadog_logs",
      "mcp__datadog-mcp__search_datadog_logs",
      "mcp__datadog-mcp__search_datadog_metrics",
      "mcp__datadog-mcp__get_datadog_metric",
      "Bash(gh api:*)",
      "Bash(CIRCLECI_TOKEN=$\\(cat ~/.circleci/token\\) bin/failedci)"
    ],
    "additionalDirectories": [
      "~/"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/git-c-rewrite.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/bundle-exec-rewrite.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/gh-pr-create-rewrite.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-builtin-replaceable.sh",
            "statusMessage": "Checking for tool-replaceable commands..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-git-add-all.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-heredoc.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-pr-ready-on-draft.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-force-push.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-manual-migration-write.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/lint.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "nit@nit": true
  },
  "extraKnownMarketplaces": {
    "soc-experience": {
      "source": {
        "source": "github",
        "repo": "huntresslabs/soc-experience"
      },
      "autoUpdate": true
    },
    "nit": {
      "source": {
        "source": "github",
        "repo": "joshuazd/nit"
      },
      "autoUpdate": true
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Hunting",
      "Wrecking hackers",
      "Investigating",
      "Remediating",
      "Defending",
      "Detecting threats",
      "Securing",
      "Triaging",
      "Tracking",
      "Monitoring",
      "Uncovering",
      "Neutralizing",
      "Protecting",
      "Analyzing",
      "Disrupting attackers",
      "Reverse-engineering",
      "Shutting down threats",
      "Gathering intel",
      "Force multiplying"
    ]
  },
  "awaySummaryEnabled": false,
  "showClearContextOnPlanAccept": true,
  "theme": "dark-ansi",
  "preferredNotifChannel": "terminal_bell",
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "allow": [
      "$defaults",
      "Deleting your own prior `@greptileai review` trigger comments via `gh api -X DELETE /repos/{owner}/{repo}/issues/comments/{id}` — used by the watch-pull-request skill to keep PR conversations tidy. Safe because it only removes the user's own trigger comments (filtered by `user.login == me` AND `body == \"@greptileai review\"`)."
    ]
  }
}
