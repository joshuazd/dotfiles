set nocompatible
" set runtimepath-=$HOME/.vim
" set runtimepath-=$HOME/.vim/after
set backspace=indent,eol,start
set hidden
set ignorecase smartcase
set nowrap
set clipboard^=unnamedplus
set laststatus=2
set scrolloff=999
set wildmenu
set noswapfile
set showcmd
set tags=./tags,tags
filetype plugin indent on
syntax on
nnoremap L $
nnoremap H ^
nnoremap Y y$
nnoremap gb :ls<CR>:b<space>
inoremap jk <esc>
set statusline=\ %f%m%r%h%w%=[%L][%{&ff}]%y[%03p%%][%04l,%04v]
