#!/bin/sh

function git_update() {
    if ! git diff-index --quiet HEAD --; then
        return true
    else
        return false
    fi
}

function check_repos() {
    for d in ./*/
    do
        cd "$d"
        echo "$d"
        git update-index -q --refresh
        if [[ -n `git status --porcelain` || -n $(git rev-list --left-right HEAD...@'{u}' 2>/dev/null) ]]; then
            git status -u
        fi
        cd ..
    done
}
