alias ls='ls --color=auto'
alias df='df -h'
alias du='du -h -c'
alias reload='source ~/.bashrc'
alias back='cd $OLDPWD'
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ......="cd ../../../../.."
alias lt='ls -lrt'
unalias l
alias l='ls -clLF'

alias home='cd /c/Users/jzinkduda'
alias documents='cd /c/Users/jzinkduda/Documents'
alias downloads='cd /c/Users/jzinkduda/Downloads'
alias repo='cd /c/GITRepo'
alias apps='cd /c/apps'

alias wls='cd /c/apps/wls12120/user_projects/domains/mydomain/servers/myserver/logs'
alias wso='cd /c/apps/wso2esb-4.8.1/bin'
alias lessf='less +FG -N'

alias python='python3'

alias esb='sh /c/apps/wso2esb-4.8.1/bin/wso2server.sh'
alias esblog='less +F /c/apps/wso2esb-4.8.1/repository/logs/wso2carbon.log'

alias find='find . -type f -name'

alias vi='vim'
