!! material theme
!# define bg #262626
!# define fg #cccccc
!! black
!# define c_0 #1c1c1c
!! red
!# define c_1 #ff5f5f
!! green
!# define c_2 #87d787
!! yellow
!# define c_3 #ffd787
!! blue
!# define c_4 #6182b8
!! purple
!# define c_5 #c792ea
!! cyan
!# define c_6 #89ddff
!! white
!# define c_7 #bbbbbb
!! bright black
!# define c_8 #3e515b
!! bright red
!# define c_9 #d75f5f
!! bright green
!# define c_10 #87af87
!! bright yellow
!# define c_11 #ffaf5f
!! bright blue
