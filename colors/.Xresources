!special
*foreground:   fg
*background:   bg
*cursorColor:  #eeffff
/* urxvt*background: [90]#262626 */
XTerm*foreground:   fg
XTerm*background:   bg
/* XTerm*cursorColor:  bg */

!black
*color0:       c_0
*color8:       c_8
XTerm*color0:  c_0
XTerm*color8:  c_8

!red
*color1:       c_1
*color9:       c_9
XTerm*color1:  c_1
XTerm*color9:  c_9

!green
*color2:       c_2
*color10:      c_10
XTerm*color2:  c_2
XTerm*color10: c_10

!yellow
*color3:       c_3
*color11:      c_11
XTerm*color3:  c_3
XTerm*color11: c_11

!blue
*color4:       c_4
*color12:      c_12
XTerm*color4:  c_4
XTerm*color12: c_12

!magenta
*color5:       c_5
*color13:      c_13
XTerm*color5:  c_5
XTerm*color13: c_13

!cyan
*color6:       c_6
*color14:      c_14
XTerm*color6:  c_6
XTerm*color14: c_14

!white
*color7:       c_7
*color15:      c_15
XTerm*color7:  c_7
XTerm*color15: c_15


XTerm.termName: xterm-256color
XTerm*ttyModes: start ^- stop ^-
URxvt.termName: xterm-256color
URxvt*ttyModes: start ^- stop ^-

XTerm*faceName: DejaVu Sans Mono:size=10:antialias=true
URxvt*font: xft:Ubuntu Mono:size=11:antialias=true
/* URxvt*font: xft:DejaVu Sans Mono:size=10:antialias=true */

xterm*VT100*geometry: 120x35
xterm*scrollBar: false
xterm*title: XTerm
xterm*iconName: XTerm
xterm*saveLines: 50000
xterm*jumpScroll: true
xterm*scrollTtyOutput: false
xterm*utf8Title: true
XTerm*altIsNotMeta: true
XTerm*altSendsEscape: true
xterm*BorderWidth: 0

URxvt*geometry: 82x46
URxvt*scrollBar: false
URxvt*title: URxvt
URxvt*iconName: URxvt
URxvt*saveLines: 50000
URxvt*jumpScroll: true
URxvt*utf8Title: true
URxvt*modifier: alt
urxvt*internalBorder: 10
URxvt.lineSpace: 1
URxvt.letterSpace: -1
URxvt*scrollTtyOutput:      false
URxvt*scrollWithBuffer:     true
URxvt*scrollTtyKeypress:    true
URxvt.perl-ext-common: selection-to-clipboard

Xft.rgba: rgb
Xft.hintstyle: hintslight

rofi.color-enabled: true
!                  bg       fg       bg-alt   hl-bg    hl-fg
rofi.color-normal: bg,      fg,      c_0,     c_0,     c_1
rofi.color-active: fg,      c_1,     c_1,     c_1,     c_1
rofi.color-window: bg,      fg
