*customization: -color

*VT100*colorMode: on
*VT100*dynamicColors: on
xterm*dynamicColors: true
urxvt*dynamicColors: on

! nier theme
# define bg #b4af9a
# define fg #45403a
! black
# define c_0 #45403a
! red
# define c_1 #bf4243
! green
# define c_2 #525643
! yellow
# define c_3 #5b5143
! blue
# define c_4 #4c5361
! purple
# define c_5 #614c61
! cyan
# define c_6 #465953
! white
# define c_7 #999483
! bright black
