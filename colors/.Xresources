*customization: -color

*VT100*colorMode: on
*VT100*dynamicColors: on

! nier theme
# define bg #b4af9a
# define fg #45403a
! black
# define color0 #45403a
! red
# define color1 #bf4243
! green
# define color2 #525643
! yellow
# define color3 #5b5143
! blue
# define color4 #4c5361
! purple
# define color5 #614c61
! cyan
# define color6 #465953
! white
# define color7 #999483
! bright black
# define color8 #777467
! bright red
# define color9 #d75f5f
! bright green
# define color10 #81895d
! bright yellow
# define color11 #957f5f
! bright blue
# define color12 #7382a0
! bright purple
# define color13 #9c739c
! bright cyan
# define color14 #5f8c7d
! bright white
# define color15 #ffffff

! material theme
# define bg #262626
# define fg #cccccc
! black
# define color0 #1c1c1c
! red
# define color1 #ff5f5f
! green
# define color2 #87d787
! yellow
# define color3 #ffd787
! blue
# define color4 #6182b8
! purple
# define color5 #c792ea
! cyan
# define color6 #89ddff
! white
# define color7 #bbbbbb
! bright black
# define color8 #3e515b
! bright red
# define color9 #d75f5f
! bright green
# define color10 #87af87
! bright yellow
# define color11 #ffaf5f
! bright blue
# define color12 #82aaff
! bright purple
# define color13 #945eb8
! bright cyan
# define color14 #39adb5
! bright white
# define color15 #ffffff




!special
*foreground:   #cccccc
*background:   #262626
*cursorColor:  #eeffff
/* urxvt*background: [90]#262626 */
/* XTerm*foreground:   #cccccc */
/* XTerm*background:   #262626 */
/* XTerm*cursorColor:  #eeffff */

!black
*color0:       #1c1c1c
*color8:       #3e515b
/* XTerm*color0:       #1c1c1c */
/* XTerm*color8:       #3e515b */

!red
*color1:       #ff5f5f
*color9:       #d75f5f
/* XTerm*color1:       #e53935 */
/* XTerm*color9:       #ff5370 */

!green
*color2:       #87d787
*color10:      #87af87
/* XTerm*color2:       #c3e88d */
/* XTerm*color10:      #91b859 */

!yellow
*color3:       #ffd787
*color11:      #ffaf5f
/* XTerm*color3:       #ffb62c */
/* XTerm*color11:      #ffcb6b */

!blue
*color4:      #6182b8
*color12:       #82aaff
/* XTerm*color4:       #82aaff */
/* XTerm*color12:      #6182b8 */

!magenta
*color5:       #c792ea
*color13:      #945eb8
/* XTerm*color5:       #c792ea */
/* XTerm*color13:      #945eb8 */

!cyan
*color6:       #89ddff
*color14:      #39adb5
/* XTerm*color6:       #89ddff */
/* XTerm*color14:      #39adb5 */

!white
*color7:       #bbbbbb
*color15:      #ffffff
/* XTerm*color7:       #bbbbbb */
/* XTerm*color15:      #ffffff */


XTerm.termName: xterm-256color
XTerm*ttyModes: start ^- stop ^-
URxvt.termName: xterm-256color
URxvt*ttyModes: start ^- stop ^-

XTerm*faceName: DejaVu Sans Mono:size=10:antialias=true
URxvt*font: xft:Ubuntu Mono:size=11:antialias=true
/* URxvt*font: xft:DejaVu Sans Mono:size=10:antialias=true */

xterm*VT100*geometry: 120x35
xterm*scrollBar: false
xterm*title: XTerm
xterm*iconName: XTerm
xterm*saveLines: 50000
xterm*jumpScroll: true
xterm*scrollTtyOutput: false
xterm*utf8Title: true
XTerm*altIsNotMeta: true
XTerm*altSendsEscape: true
xterm*BorderWidth: 0

URxvt*geometry: 82x46
URxvt*scrollBar: false
URxvt*title: URxvt
URxvt*iconName: URxvt
URxvt*saveLines: 50000
URxvt*jumpScroll: true
URxvt*utf8Title: true
URxvt*modifier: alt
urxvt*internalBorder: 10
URxvt.lineSpace: 1
URxvt.letterSpace: -1
URxvt*scrollTtyOutput:      false
URxvt*scrollWithBuffer:     true
URxvt*scrollTtyKeypress:    true
URxvt.perl-ext-common: selection-to-clipboard

Xft.rgba: rgb
Xft.hintstyle: hintslight
