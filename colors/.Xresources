*customization: -color

*VT100*colorMode: on
*VT100*dynamicColors: on
xterm*dynamicColors: true
urxvt*dynamicColors: on

!! nier theme
!# define bg #b4af9a
!# define fg #45403a
!! black
!# define c_0 #45403a
!! red
!# define c_1 #bf4243
!! green
!# define c_2 #525643
!! yellow
!# define c_3 #5b5143
!! blue
!# define c_4 #4c5361
!! purple
!# define c_5 #614c61
!! cyan
!# define c_6 #465953
!! white
!# define c_7 #999483
!! bright black
!# define c_8 #777467
!! bright red
!# define c_9 #d75f5f
!! bright green
!# define c_10 #81895d
!! bright yellow
!# define c_11 #957f5f
!! bright blue
!# define c_12 #7382a0
!! bright purple
!# define c_13 #9c739c
!! bright cyan
!# define c_14 #5f8c7d
!! bright white
!# define c_15 #ffffff

! material theme
# define bg #262626
# define fg #cccccc
! black
# define c_0 #1c1c1c
! red
# define c_1 #ff5f5f
! green
# define c_2 #87d787
! yellow
# define c_3 #ffd787
! blue
# define c_4 #6182b8
! purple
# define c_5 #c792ea
! cyan
# define c_6 #89ddff
! white
# define c_7 #bbbbbb
! bright black
# define c_8 #3e515b
! bright red
# define c_9 #d75f5f
! bright green
# define c_10 #87af87
! bright yellow
# define c_11 #ffaf5f
! bright blue
# define c_12 #82aaff
! bright purple
# define c_13 #945eb8
! bright cyan
# define c_14 #39adb5
! bright white
